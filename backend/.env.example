PORT=5000
MONGODB_URI=mongodb://localhost:27017/kudegowo
JWT_SECRET=your_jwt_secret_key_here
PAYSTACK_SECRET_KEY=your_paystack_secret_key
NODE_ENV=production
RAILWAY_ENVIRONMENT=production

# School Wallet Feature (defaults shown — no config needed to start)
# PAYMENT_CRON_INTERVAL=*/15 * * * *   # How often to process due payments
# MAX_PAYMENT_RETRIES=3                 # Retries before terminal failure
# STALE_LOCK_MINUTES=30                 # Minutes before a 'processing' lock is considered stale
